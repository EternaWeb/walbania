# Public site origin used for canonical URLs and publish links
SITE_URL=https://wonderalbania.com

# Supabase Project Settings > API Keys
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Password-only admin access
ADMIN_PASSWORD=
# Generate a random value of at least 32 characters
ADMIN_SESSION_SECRET=

# Identifies the low-volume admin place search to OpenStreetMap Nominatim
GEOCODER_USER_AGENT=WonderAlbaniaAdmin/1.0 (https://wonderalbania.com; hello@wonderalbania.com)

